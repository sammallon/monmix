# Default: let git auto-detect text and normalize line endings on commit.
* text=auto

# Shell scripts and git hooks must keep LF endings even on Windows checkouts —
# bash chokes on "#!/usr/bin/env bash\r" if CRLF leaks in.
tools/git-hooks/* text eol=lf
*.sh text eol=lf

# ESP-IDF / CMake source: explicit LF for portability.
*.c   text eol=lf
*.h   text eol=lf
*.cpp text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.yml text eol=lf
*.csv text eol=lf
