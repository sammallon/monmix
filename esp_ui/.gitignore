# Generated sdkconfig (sdkconfig.defaults is the committed source of truth)
sdkconfig
sdkconfig.old

# Session-scoped log captures (build_log.txt, flash_log.txt, serial_log.txt,
# serial_capture.txt, console_capture.txt), coredumps pulled off-device,
# runtime monmix-NNNN.log files fetched via tools/fetch_b64.py, and
# screenshots fetched via tools/fetch_screenshot.py.
mcp_tee.log
*_log.txt
*_capture.txt
coredump-*.elf
monmix-*.log
screenshot*.png
before*.png
after*.png
demo-*.png

# Local forensic records of on-device incidents — kept for personal
# reference but never pushed (may include local IPs / network details).
forensics/

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# OS junk
.DS_Store
Thumbs.db

# Local Claude Code session data
.claude/

# Credentials — NEVER commit. Real values live in main/secrets.h
